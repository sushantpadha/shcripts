#!/bin/bash
# ==========================================================
# enable-nvidia.sh
# Re-enable NVIDIA GPU on Ubuntu (after disable-nvidia.sh)
#
# This restores NVIDIA drivers, unmasks services,
# removes blacklist, rebuilds initramfs, and switches
# PRIME mode to 'on-demand' for hybrid GPU usage.
#
# Based on ChatGPT guide: https://chatgpt.com/c/68e93ba8-5f54-8321-91d1-c3673dbfd79b
# ==========================================================

echo "⚠️  This will re-enable NVIDIA GPU and power management services."
read -p "Press Enter or Ctrl+C to abort..."

# ==========================================================
# 1. Unmask and re-enable NVIDIA-related services
# ==========================================================
# 'unmask' removes the /dev/null symlink so the service can start again
# 'enable' ensures it runs on boot if installed
echo -e "\n>>> Unmasking and enabling NVIDIA services..."
sudo systemctl unmask nvidia-powerd.service 2>/dev/null
sudo systemctl enable --now nvidia-powerd.service 2>/dev/null
sudo systemctl enable --now nvidia-persistenced.service 2>/dev/null
echo "✔️  NVIDIA services unmasked and enabled."
read -p "Press Enter or Ctrl+C to continue..."

# ==========================================================
# 2. Remove blacklist file for NVIDIA kernel modules
# ==========================================================
# This restores the driver’s ability to load normally at boot.
echo -e "\n>>> Removing NVIDIA blacklist..."
if [ -f /etc/modprobe.d/blacklist-nvidia.conf ]; then
    sudo rm /etc/modprobe.d/blacklist-nvidia.conf
    echo "✔️  Blacklist removed."
else
    echo "(No blacklist found, skipping.)"
fi
read -p "Press Enter or Ctrl+C to continue..."

# ==========================================================
# 3. Rebuild initramfs so NVIDIA modules are included again
# ==========================================================
echo -e "\n>>> Updating initramfs..."
sudo update-initramfs -u
echo "✔️  Initramfs updated."
read -p "Press Enter or Ctrl+C to continue..."

# ==========================================================
# 4. Switch PRIME mode to 'on-demand'
# ==========================================================
# 'prime-select on-demand' allows GPU offload when needed
echo -e "\n>>> Switching to NVIDIA on-demand mode..."
sudo prime-select on-demand
echo "✔️  PRIME mode set to on-demand."
read -p "Press Enter or Ctrl+C to continue..."

# ==========================================================
# 5. Reboot prompt and verification commands
# ==========================================================
echo -e "\n✅ All steps done. Please reboot to apply changes."
echo "After reboot, verify with:"
echo "  nvidia-smi"
echo "  prime-select query"
echo "  glxinfo | grep 'OpenGL renderer'"
echo
echo "Expected result: NVIDIA visible in nvidia-smi, PRIME reports 'on-demand'."

